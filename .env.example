# ============================================================
# AI Brand Studio — MVP (Phase 0 shell, mocked services)
# ============================================================
# All values are OPTIONAL for the demo. The app runs with mocks
# out of the box. Set these when you wire up real services.

# --- Studio identity ---
# Display name shown across the marketing site + portal. Replace before launch.
NEXT_PUBLIC_STUDIO_NAME="Lumen"
NEXT_PUBLIC_STUDIO_TAGLINE="Your brand, built by AI. Delivered in hours, not months."

# --- Demo mode flag ---
# When "true" (default for MVP), the app uses mocked payments, auth, DB,
# voice, and the agent pipeline. Flip to "false" once real services are wired.
NEXT_PUBLIC_DEMO_MODE="true"

